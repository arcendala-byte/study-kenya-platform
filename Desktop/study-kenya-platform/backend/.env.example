# ─────────────────────────────────────────────
# StudyKenya Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# Supabase (Required)
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-64-chars

# CORS — comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Admin Setup (used only during seeding, can be removed after first run)
ADMIN_EMAIL=admin@studykenya.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!
